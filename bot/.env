# LOOP
ATTEMPS=1

# FILES
FOLDER=temp
PERSISTENT=true

# PROXY
PROXIES=[null]

# SCRAPER
BASE_URL="https://www.g2.com/categories/crm"

# NAVIGATOR
BINARY_LOCATION="/usr/bin/microsoft-edge"
REMOTE_URL=null
EXTRA_ARGS=["--no-sandbox","--disable-dev-shm-usage","--disable-gpu"]

# FINGERPRINT
REGION_CODE="CO"
SEED="default_seed"
OS_TYPE="Linux x86_64" #Win32
CONFIG_PATH="fingerprint_config.json"